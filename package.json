{
	"name": "my-app",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "yarn@4.5.1",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"lint": "oxlint . && node scripts/no-div-span.mjs",
		"lint:fix": "oxlint . --fix",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "yarn vitest run --pass-with-no-tests --path-ignore-patterns e2e --path-ignore-patterns crater",
		"test:integration": "yarn vitest run --pass-with-no-tests --path-ignore-patterns e2e --path-ignore-patterns crater --test-name-pattern integration",
		"test:e2e": "yarn playwright test"
	},
	"devDependencies": {
		"@fontsource/fira-mono": "^5.2.7",
		"@neoconfetti/svelte": "^2.2.2",
		"@playwright/test": "^1.52.0",
		"@simplewebauthn/types": "^12.0.0",
		"@sveltejs/adapter-node": "^5.2.9",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^25.5.2",
		"oxlint": "latest",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"typescript": "^5.9.3",
		"vite": "8",
		"vitest": "^3.0.0"
	},
	"dependencies": {
		"@iconify/svelte": "^5.2.1",
		"@noble/post-quantum": "^0.6.1",
		"@reown/appkit": "^1.8.19",
		"@reown/appkit-adapter-wagmi": "^1.8.19",
		"@simplewebauthn/browser": "^13.3.0",
		"@tonconnect/sdk": "^3.4.1",
		"@wagmi/core": "^3.4.1",
		"prosekit": "^0.19.0",
		"shiki": "^1.29.0",
		"viem": "^2.47.6"
	},
	"devDependenciesMeta": {
		"@types/bun": "npm:@types/bun@1.3.13"
	}
}
