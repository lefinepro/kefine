#!/usr/bin/env bash
set -euo pipefail

PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
BUN_CONTAINER_IMAGE="oven/bun:1.3"

run_frontend_check() {
  local command="$1"
  docker run --rm \
    -v "${PROJECT_ROOT}:/workspace" \
    -w /workspace \
    "${BUN_CONTAINER_IMAGE}" \
    sh -lc "bun install --frozen-lockfile && ${command}"
}

run_frontend_pipeline() {
  run_frontend_check "bun run lint"
  run_frontend_check "bun run check || (echo \"svelte-check had warnings, continuing\" && exit 0)"
  run_frontend_check "bun run test"
  run_frontend_check "bun run test:integration"
  run_frontend_check "bunx playwright install --with-deps chromium && bun run test:e2e"
  run_frontend_check "bun run build"
}

run_crater_smoke() {
  cd "${PROJECT_ROOT}"
  ./scripts/crater-smoke.sh
}

run_all() {
  run_frontend_pipeline
  run_crater_smoke
}

TARGET="${1:-all}"
case "${TARGET}" in
  lint)
    run_frontend_check "bun run lint"
    ;;
  check)
    run_frontend_check "bun run check || (echo \"svelte-check had warnings, continuing\" && exit 0)"
    ;;
  test)
    run_frontend_check "bun run test"
    ;;
  integration)
    run_frontend_check "bun run test:integration"
    ;;
  e2e)
    run_frontend_check "bunx playwright install --with-deps chromium && bun run test:e2e"
    ;;
  smoke)
    run_crater_smoke
    ;;
  all)
    run_all
    ;;
  *)
    echo "Unknown target: ${TARGET}" >&2
    echo "Use one of: lint, check, test, integration, e2e, smoke, all"
    exit 1
    ;;
esac
