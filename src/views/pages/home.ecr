            Draft
          </button>
          <button type="submit" variant="primary">Post</button>
        </kf-comment-actions>
      </kf-comment-form>
    </kf-card-comments>
  </kf-card>

  <kf-card data-post-id="post-3" variant="post" role="article" tabindex="0" aria-label="Post: TAC CSS Deep Dive">
    <kf-card-close></kf-card-close>
    <kf-card-header>
      <kf-card-avatar aria-hidden="true">
