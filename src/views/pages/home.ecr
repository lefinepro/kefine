<!-- Posts Feed - Infinite Scroll Layout -->
<kf-feed>
  <kf-card data-post-id="post-1" variant="post" role="article" tabindex="0" aria-label="Post: Getting Started with Kefine">
    <kf-card-close></kf-card-close>
    <kf-card-header>
      <kf-card-avatar aria-hidden="true">
        <kf-icon name="user"></kf-icon>
      </kf-card-avatar>
      <kf-card-meta>
        <kf-card-author>Admin</kf-card-author>
        <kf-card-date>December 31, 2025</kf-card-date>
      </kf-card-meta>
    </kf-card-header>
    <kf-card-body>
      <kf-card-title>Getting Started with Kefine</kf-card-title>
      <kf-card-content>
        Learn how to build modern web applications using the Kefine template. This guide covers the TAC CSS architecture, Lit components integration, and ECR templating system.
      </kf-card-content>
    </kf-card-body>
    <kf-card-footer>
      <kf-card-action aria-label="Like post">
        <kf-icon name="heart"></kf-icon>
        <span>24</span>
      </kf-card-action>
      <kf-card-action aria-label="View comments">
        <kf-icon name="comment"></kf-icon>
        <span>8</span>
      </kf-card-action>
      <kf-card-action aria-label="Share post">
        <kf-icon name="share"></kf-icon>
      </kf-card-action>
    </kf-card-footer>
    <kf-card-comments aria-label="Comments section">
      <kf-card-comments-header>
        <span>Comments (8)</span>
        <button type="button">Add Comment</button>
      </kf-card-comments-header>
      <kf-comment>
        <kf-comment-header>
          <kf-comment-author>Jane Doe</kf-comment-author>
          <kf-comment-date>2 hours ago</kf-comment-date>
        </kf-comment-header>
        <kf-comment-body>Great introduction! The TAC methodology is really intuitive.</kf-comment-body>
      </kf-comment>
      <kf-comment>
        <kf-comment-header>
          <kf-comment-author>John Smith</kf-comment-author>
          <kf-comment-date>5 hours ago</kf-comment-date>
        </kf-comment-header>
        <kf-comment-body>Looking forward to trying this out in my next project.</kf-comment-body>
      </kf-comment>
      <kf-comment-form>
        <kf-combobox placeholder="Write a comment..." min-chars="0" aria-label="Comment input">
          <kf-icon slot="icon" name="edit"></kf-icon>
        </kf-combobox>
        <kf-comment-actions>
          <button type="button" variant="secondary" title="Save as draft">
            <kf-icon name="document"></kf-icon>
            Draft
          </button>
          <button type="submit" variant="primary">Post</button>
        </kf-comment-actions>
      </kf-comment-form>
    </kf-card-comments>
  </kf-card>

  <kf-card data-post-id="post-2" variant="post" role="article" tabindex="0" aria-label="Post: Lit Components">
    <kf-card-close></kf-card-close>
    <kf-card-header>
      <kf-card-avatar aria-hidden="true">
        <kf-icon name="code"></kf-icon>
      </kf-card-avatar>
      <kf-card-meta>
        <kf-card-author>Developer</kf-card-author>
        <kf-card-date>December 30, 2025</kf-card-date>
      </kf-card-meta>
    </kf-card-header>
    <kf-card-body>
      <kf-card-title>Exploring Lit Components</kf-card-title>
      <kf-card-content>
        Discover the power of Lit's lightweight web components. From buttons and badges to complex form controls, everything is designed with accessibility in mind.
      </kf-card-content>
    </kf-card-body>
    <kf-card-footer>
      <kf-card-action aria-label="Like post">
