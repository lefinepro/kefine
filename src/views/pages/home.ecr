        <kf-icon name="document" size="3xl"></kf-icon>
      </kf-feature-icon>
      <h4>ECR Templates</h4>
      <p>Server-side templating with Crystal</p>
    </kf-feature-item>

    <kf-feature-item>
      <kf-feature-icon>
        <kf-icon name="grid" size="3xl"></kf-icon>
      </kf-feature-icon>
      <h4>Lit Components</h4>
      <p>Lightweight web components library</p>
    </kf-feature-item>
  </kf-grid>
</kf-section>

<!-- Keyboard Shortcuts -->
<kf-section>
  <kf-section-header>
    <kf-section-title>Keyboard Shortcuts</kf-section-title>
  </kf-section-header>

  <kf-card>
    <kf-card-body>
      <kf-shortcut-list>
        <kf-shortcut-item>
          <span>Open search</span>
          <kbd>/</kbd>
        </kf-shortcut-item>
        <kf-shortcut-item>
          <span>Toggle sidebar</span>
          <kf-kbd-group>
            <kbd>Ctrl</kbd>
            <kbd>B</kbd>
          </kf-kbd-group>
        </kf-shortcut-item>
        <kf-shortcut-item>
          <span>Toggle sound</span>
          <kbd>M</kbd>
        </kf-shortcut-item>
        <kf-shortcut-item>
          <span>Close panel</span>
          <kbd>Esc</kbd>
        </kf-shortcut-item>
      </kf-shortcut-list>
    </kf-card-body>
  </kf-card>
</kf-section>
