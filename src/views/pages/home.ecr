<!-- Posts Section - Vertical Layout with Expandable View -->
<kf-section>
  <kf-section-header>
    <kf-section-title>Latest Posts</kf-section-title>
  </kf-section-header>

  <kf-post-list>
    <kf-post data-post-id="post-1" role="article" tabindex="0" aria-label="Post: Getting Started with Kefine">
      <kf-post-close></kf-post-close>
      <kf-post-header>
        <kf-post-avatar aria-hidden="true">
          <kf-icon name="user"></kf-icon>
        </kf-post-avatar>
        <kf-post-meta>
          <kf-post-author>Admin</kf-post-author>
          <kf-post-date>December 31, 2025</kf-post-date>
        </kf-post-meta>
      </kf-post-header>
      <kf-post-body>
        <kf-post-title>Getting Started with Kefine</kf-post-title>
        <kf-post-content>
          Learn how to build modern web applications using the Kefine template. This guide covers the TAC CSS architecture, Lit components integration, and ECR templating system.
        </kf-post-content>
      </kf-post-body>
      <kf-post-footer>
        <kf-post-action aria-label="Like post">
          <kf-icon name="heart"></kf-icon>
          <span>24</span>
        </kf-post-action>
        <kf-post-action aria-label="View comments">
          <kf-icon name="comment"></kf-icon>
          <span>8</span>
        </kf-post-action>
        <kf-post-action aria-label="Share post">
          <kf-icon name="share"></kf-icon>
        </kf-post-action>
      </kf-post-footer>
      <kf-post-comments aria-label="Comments section">
        <kf-post-comments-header>
          <span>Comments (8)</span>
          <button type="button">Add Comment</button>
        </kf-post-comments-header>
        <kf-comment>
          <kf-comment-header>
            <kf-comment-author>Jane Doe</kf-comment-author>
            <kf-comment-date>2 hours ago</kf-comment-date>
          </kf-comment-header>
          <kf-comment-body>Great introduction! The TAC methodology is really intuitive.</kf-comment-body>
        </kf-comment>
        <kf-comment>
          <kf-comment-header>
            <kf-comment-author>John Smith</kf-comment-author>
            <kf-comment-date>5 hours ago</kf-comment-date>
          </kf-comment-header>
          <kf-comment-body>Looking forward to trying this out in my next project.</kf-comment-body>
        </kf-comment>
        <kf-comment-form>
          <input type="text" placeholder="Write a comment...">
          <button type="submit">Post</button>
        </kf-comment-form>
      </kf-post-comments>
    </kf-post>

    <kf-post data-post-id="post-2" role="article" tabindex="0" aria-label="Post: Lit Components">
      <kf-post-close></kf-post-close>
      <kf-post-header>
        <kf-post-avatar aria-hidden="true">
          <kf-icon name="code"></kf-icon>
        </kf-post-avatar>
