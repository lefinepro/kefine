      </kf-card-action>
    </kf-card-footer>
    <kf-card-comments aria-label="Comments section">
      <kf-card-comments-header>
        <span>Comments (15)</span>
        <button type="button">Add Comment</button>
      </kf-card-comments-header>
      <kf-comment>
        <kf-comment-header>
          <kf-comment-author>Alex Chen</kf-comment-author>
          <kf-comment-date>1 day ago</kf-comment-date>
        </kf-comment-header>
        <kf-comment-body>The accessibility features are fantastic. Great work!</kf-comment-body>
