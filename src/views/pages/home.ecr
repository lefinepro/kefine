      </kf-post-comments>
    </kf-post>

    <kf-post data-post-id="post-3" role="article" tabindex="0" aria-label="Post: TAC CSS Deep Dive">
      <kf-post-close></kf-post-close>
      <kf-post-header>
        <kf-post-avatar aria-hidden="true">
          <kf-icon name="palette"></kf-icon>
        </kf-post-avatar>
        <kf-post-meta>
          <kf-post-author>Designer</kf-post-author>
          <kf-post-date>December 29, 2025</kf-post-date>
        </kf-post-meta>
      </kf-post-header>
      <kf-post-body>
        <kf-post-title>TAC CSS: A Deep Dive</kf-post-title>
        <kf-post-content>
          Understanding the Tags, Attributes, Classes hierarchy. Learn why this approach leads to more maintainable and scalable stylesheets in your web component projects.
        </kf-post-content>
      </kf-post-body>
      <kf-post-footer>
        <kf-post-action aria-label="Like post">
          <kf-icon name="heart"></kf-icon>
          <span>67</span>
        </kf-post-action>
        <kf-post-action aria-label="View comments">
          <kf-icon name="comment"></kf-icon>
          <span>23</span>
        </kf-post-action>
        <kf-post-action aria-label="Share post">
          <kf-icon name="share"></kf-icon>
        </kf-post-action>
      </kf-post-footer>
      <kf-post-comments aria-label="Comments section">
        <kf-post-comments-header>
          <span>Comments (23)</span>
          <button type="button">Add Comment</button>
        </kf-post-comments-header>
        <kf-comment>
          <kf-comment-header>
            <kf-comment-author>Sarah Wilson</kf-comment-author>
            <kf-comment-date>2 days ago</kf-comment-date>
          </kf-comment-header>
          <kf-comment-body>This changed how I think about CSS architecture. Brilliant!</kf-comment-body>
        </kf-comment>
        <kf-comment-form>
          <input type="text" placeholder="Write a comment...">
          <button type="submit">Post</button>
        </kf-comment-form>
      </kf-post-comments>
    </kf-post>
  </kf-post-list>
</kf-section>

<!-- Foundation Section -->
<kf-section>
  <kf-section-header>
    <kf-section-title>Foundation</kf-section-title>
  </kf-section-header>

  <kf-grid cols="2">
    <!-- TAC CSS Card -->
    <kf-card>
      <kf-card-header>
        <kf-card-title>TAC CSS Architecture</kf-card-title>
        <kf-badge variant="primary">Core</kf-badge>
      </kf-card-header>
      <kf-card-body>
        <p>A CSS methodology for the Web Components era. Style custom HTML tags, define custom attributes, then customize with utility classes.</p>
        <pre><code>/* Step 1: Style the tag */
kf-badge {
  display: inline-flex;
  padding: 4px;
}

/* Step 2: Style attributes */
kf-badge[variant=primary] {
  background: var(--kf-color-accent-primary);
}

/* Step 3: Utility classes */
&lt;kf-badge class="mar-r-sm"&gt;</code></pre>
      </kf-card-body>
      <kf-card-footer>
        <button type="button">Learn More</button>
      </kf-card-footer>
    </kf-card>

    <!-- ECR Templates Card -->
    <kf-card>
      <kf-card-header>
        <kf-card-title>ECR Templating</kf-card-title>
        <kf-badge variant="success">Active</kf-badge>
      </kf-card-header>
      <kf-card-body>
        <p>Embedded Crystal for server-side templating. Create reusable templates with proper inheritance and partials.</p>
        <pre><code>&lt;%# layouts/main.ecr %&gt;
&lt;!DOCTYPE html&gt;
&lt;html&gt;
&lt;head&gt;
  &lt;title&gt;&lt;%= title %&gt;&lt;/title&gt;
&lt;/head&gt;
&lt;body&gt;
  &lt;%= content %&gt;
&lt;/body&gt;
&lt;/html&gt;</code></pre>
      </kf-card-body>
      <kf-card-footer>
        <button type="button">View Docs</button>
      </kf-card-footer>
    </kf-card>
  </kf-grid>
</kf-section>

<!-- Component Examples Section -->
<kf-section>
  <kf-section-header>
    <kf-section-title>Component Examples</kf-section-title>
  </kf-section-header>

  <kf-grid cols="3">
    <!-- Button Component Demo -->
    <kf-card>
      <kf-card-header>
        <kf-card-title>button</kf-card-title>
      </kf-card-header>
      <kf-card-body>
        <p>Native button element with TAC styling.</p>
        <kf-button-group>
          <button type="button" variant="primary">Primary</button>
          <button type="button" variant="secondary">Secondary</button>
          <button type="button" variant="success">Success</button>
        </kf-button-group>
      </kf-card-body>
    </kf-card>

    <!-- Badge Component Demo -->
    <kf-card>
      <kf-card-header>
        <kf-card-title>kf-badge</kf-card-title>
      </kf-card-header>
      <kf-card-body>
        <p>Status indicators with semantic variants.</p>
        <kf-badge-group>
          <kf-badge>Default</kf-badge>
          <kf-badge variant="primary">Primary</kf-badge>
          <kf-badge variant="success">Success</kf-badge>
          <kf-badge variant="warning">Warning</kf-badge>
          <kf-badge variant="error">Error</kf-badge>
        </kf-badge-group>
      </kf-card-body>
    </kf-card>

    <!-- Input Component Demo -->
    <kf-card>
      <kf-card-header>
        <kf-card-title>input</kf-card-title>
      </kf-card-header>
      <kf-card-body>
        <p>Native input with icon support.</p>
        <kf-input-group>
          <label for="demo-search">Search</label>
          <kf-search-input>
            <kf-icon name="search"></kf-icon>
            <input id="demo-search" type="search" placeholder="Type to search...">
          </kf-search-input>
        </kf-input-group>
      </kf-card-body>
    </kf-card>

    <!-- Switch Component Demo -->
    <kf-card>
      <kf-card-header>
        <kf-card-title>checkbox</kf-card-title>
      </kf-card-header>
      <kf-card-body>
        <p>Toggle switches using native checkboxes.</p>
        <kf-switch-group>
          <label><input type="checkbox" checked> Dark Mode</label>
          <label><input type="checkbox"> Notifications</label>
          <label><input type="checkbox"> Auto-save</label>
        </kf-switch-group>
      </kf-card-body>
    </kf-card>

    <!-- Progress Component Demo -->
    <kf-card>
      <kf-card-header>
        <kf-card-title>progress</kf-card-title>
      </kf-card-header>
      <kf-card-body>
        <p>Native progress elements.</p>
        <kf-progress-group>
          <progress value="25" max="100">25%</progress>
          <progress value="50" max="100">50%</progress>
          <progress value="75" max="100">75%</progress>
        </kf-progress-group>
      </kf-card-body>
    </kf-card>

    <!-- Icon Component Demo -->
    <kf-card>
      <kf-card-header>
        <kf-card-title>kf-icon</kf-card-title>
      </kf-card-header>
      <kf-card-body>
        <p>Local Carbon Design SVG icons.</p>
        <kf-icon-group>
          <kf-icon name="home" size="lg"></kf-icon>
          <kf-icon name="search" size="lg"></kf-icon>
          <kf-icon name="settings" size="lg"></kf-icon>
          <kf-icon name="user" size="lg"></kf-icon>
        </kf-icon-group>
      </kf-card-body>
    </kf-card>
  </kf-grid>
</kf-section>

<!-- Custom Components Section -->
<kf-section>
  <kf-section-header>
    <kf-section-title>Custom Components (kf-*)</kf-section-title>
  </kf-section-header>

  <kf-grid cols="3">
    <!-- Card Component -->
    <kf-card variant="outlined">
      <kf-card-header>
        <kf-card-title>kf-card</kf-card-title>
      </kf-card-header>
      <kf-card-body>
        <p>A flexible container component with header, body, and footer sections.</p>
      </kf-card-body>
    </kf-card>

    <!-- Badge Component -->
    <kf-card variant="outlined">
      <kf-card-header>
        <kf-card-title>kf-badge</kf-card-title>
      </kf-card-header>
      <kf-card-body>
        <p>Status indicators with multiple variants.</p>
        <kf-badge-group>
          <kf-badge>Default</kf-badge>
          <kf-badge variant="primary">Primary</kf-badge>
          <kf-badge variant="success">Success</kf-badge>
          <kf-badge variant="warning">Warning</kf-badge>
          <kf-badge variant="error">Error</kf-badge>
        </kf-badge-group>
      </kf-card-body>
    </kf-card>

    <!-- Search Component -->
    <kf-card variant="outlined">
      <kf-card-header>
        <kf-card-title>kf-search</kf-card-title>
      </kf-card-header>
      <kf-card-body>
        <p>Search input with icon and keyboard shortcut indicator.</p>
        <kf-search>
          <kf-search-icon>
            <kf-icon name="search"></kf-icon>
          </kf-search-icon>
          <kf-search-input>
            <input type="search" placeholder="Search...">
          </kf-search-input>
        </kf-search>
      </kf-card-body>
    </kf-card>

    <!-- Navigation Component -->
    <kf-card variant="outlined">
      <kf-card-header>
        <kf-card-title>kf-nav-item</kf-card-title>
      </kf-card-header>
      <kf-card-body>
        <p>Navigation items with icon and text.</p>
        <nav>
          <kf-nav-item active>
            <kf-icon name="home"></kf-icon>
            <span>Active Item</span>
          </kf-nav-item>
          <kf-nav-item>
            <kf-icon name="grid"></kf-icon>
            <span>Normal Item</span>
          </kf-nav-item>
        </nav>
      </kf-card-body>
    </kf-card>

    <!-- Grid Component -->
    <kf-card variant="outlined">
      <kf-card-header>
        <kf-card-title>kf-grid</kf-card-title>
      </kf-card-header>
      <kf-card-body>
        <p>Responsive grid layout with configurable columns.</p>
        <kf-grid cols="3">
          <kf-grid-item>1</kf-grid-item>
          <kf-grid-item>2</kf-grid-item>
          <kf-grid-item>3</kf-grid-item>
        </kf-grid>
      </kf-card-body>
    </kf-card>

    <!-- Section Component -->
    <kf-card variant="outlined">
      <kf-card-header>
        <kf-card-title>kf-section</kf-card-title>
      </kf-card-header>
      <kf-card-body>
        <p>Content sections with header and title for organizing page content.</p>
      </kf-card-body>
    </kf-card>
  </kf-grid>
</kf-section>

<!-- Features Section -->
<kf-section>
  <kf-section-header>
    <kf-section-title>Features</kf-section-title>
  </kf-section-header>

  <kf-grid cols="4">
    <kf-feature-item>
