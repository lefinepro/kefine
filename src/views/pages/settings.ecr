<kt-section>
  <kt-section-header>
    <kt-section-title>Settings</kt-section-title>
  </kt-section-header>

  <kt-grid cols="2">
    <!-- Appearance Settings -->
    <kt-card>
      <kt-card-header>
        <kt-card-title>Appearance</kt-card-title>
      </kt-card-header>
      <kt-card-body>
        <kt-settings>
          <kt-setting-item>
            <kt-setting-label slot="label">
              <span>Theme</span>
              <small>Choose your preferred color scheme</small>
            </kt-setting-label>
            <wa-select slot="control" id="theme-select">
              <option value="dark" selected>Dark</option>
              <option value="light">Light</option>
              <option value="system">System</option>
            </wa-select>
          </kt-setting-item>

          <kt-setting-item>
            <kt-setting-label slot="label">
              <span>Font Size</span>
              <small>Adjust the base font size</small>
            </kt-setting-label>
            <wa-select slot="control" id="font-size-select">
              <option value="small">Small</option>
              <option value="medium" selected>Medium</option>
              <option value="large">Large</option>
            </wa-select>
          </kt-setting-item>

          <kt-setting-item>
            <kt-setting-label slot="label">
              <span>Animations</span>
              <small>Enable or disable UI animations</small>
            </kt-setting-label>
            <wa-switch slot="control" id="animations-setting" checked></wa-switch>
          </kt-setting-item>

          <kt-setting-item>
            <kt-setting-label slot="label">
              <span>Compact Mode</span>
              <small>Reduce spacing throughout the interface</small>
            </kt-setting-label>
            <wa-switch slot="control" id="compact-mode-setting"></wa-switch>
          </kt-setting-item>
        </kt-settings>
      </kt-card-body>
    </kt-card>

    <!-- Audio Settings -->
    <kt-card>
      <kt-card-header>
        <kt-card-title>Audio</kt-card-title>
      </kt-card-header>
      <kt-card-body>
        <kt-settings>
          <kt-setting-item>
            <kt-setting-label slot="label">
              <span>Sound Effects</span>
              <small>Play sounds for interactions</small>
            </kt-setting-label>
            <wa-switch slot="control" id="sound-effects-setting"></wa-switch>
          </kt-setting-item>

          <kt-setting-item>
            <kt-setting-label slot="label">
              <span>Notification Sounds</span>
              <small>Audio alerts for notifications</small>
            </kt-setting-label>
            <wa-switch slot="control" id="notification-sounds-setting" checked></wa-switch>
          </kt-setting-item>

          <kt-setting-item>
            <kt-setting-label slot="label">
              <span>Volume</span>
              <small>Adjust the master volume level</small>
            </kt-setting-label>
            <wa-input slot="control" type="range" id="volume-setting" min="0" max="100" value="75"></wa-input>
          </kt-setting-item>
        </kt-settings>
      </kt-card-body>
    </kt-card>

    <!-- Keyboard Settings -->
    <kt-card>
      <kt-card-header>
        <kt-card-title>Keyboard</kt-card-title>
      </kt-card-header>
      <kt-card-body>
        <kt-settings>
          <kt-setting-item>
            <kt-setting-label slot="label">
              <span>Keyboard Shortcuts</span>
              <small>Enable keyboard navigation</small>
            </kt-setting-label>
            <wa-switch slot="control" id="shortcuts-setting" checked></wa-switch>
          </kt-setting-item>

          <kt-setting-item>
            <kt-setting-label slot="label">
              <span>Vim Mode</span>
              <small>Use vim-style key bindings</small>
            </kt-setting-label>
            <wa-switch slot="control" id="vim-mode-setting"></wa-switch>
          </kt-setting-item>
        </kt-settings>
      </kt-card-body>
    </kt-card>

    <!-- Privacy Settings -->
    <kt-card>
      <kt-card-header>
        <kt-card-title>Privacy</kt-card-title>
      </kt-card-header>
      <kt-card-body>
        <kt-settings>
          <kt-setting-item>
            <kt-setting-label slot="label">
              <span>Analytics</span>
              <small>Help improve the application</small>
            </kt-setting-label>
            <wa-switch slot="control" id="analytics-setting" checked></wa-switch>
          </kt-setting-item>

          <kt-setting-item>
            <kt-setting-label slot="label">
              <span>Save Preferences</span>
              <small>Remember your settings locally</small>
            </kt-setting-label>
            <wa-switch slot="control" id="save-prefs-setting" checked></wa-switch>
          </kt-setting-item>
        </kt-settings>
      </kt-card-body>
    </kt-card>
  </kt-grid>
</kt-section>

<kt-section>
  <kt-section-header>
    <kt-section-title>Actions</kt-section-title>
  </kt-section-header>

  <kt-card>
    <kt-card-body>
      <div class="d-flex gap-md flex-wrap">
        <wa-button class="bg-surface">Export Settings</wa-button>
        <wa-button class="bg-surface">Import Settings</wa-button>
        <wa-button class="text-error">Reset to Defaults</wa-button>
      </div>
    </kt-card-body>
  </kt-card>
</kt-section>
