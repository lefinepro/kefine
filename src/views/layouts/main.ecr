<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/dist/assets/style.css">
</head>
<body>
  <kf-app>
    <kf-sidebar id="sidebar" hidden>
      <%= KemalTemplate.render_partial("sidebar") %>
    </kf-sidebar>

    <kf-main>
      <%= KemalTemplate.render_partial("topbar") %>
      <kf-content>
        <%= content %>
      </kf-content>
    </kf-main>
  </kf-app>
  <script type="module" src="/dist/assets/main.js"></script>
</body>
</html>
