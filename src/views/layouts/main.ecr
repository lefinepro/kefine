<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Kemal Template</title>

  <!-- TAC CSS Architecture -->
  <link rel="stylesheet" href="/css/tokens.css">
  <link rel="stylesheet" href="/css/html-tags.css">
  <link rel="stylesheet" href="/css/custom-tags.css">
  <link rel="stylesheet" href="/css/utility-classes.css">

  <!-- Web Awesome Components -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@aspect-ui/webawesome@3.1.0/dist/themes/dark.css">
  <script type="module" src="https://cdn.jsdelivr.net/npm/@aspect-ui/webawesome@3.1.0/dist/webawesome.js"></script>

  <!-- Custom fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Commit+Mono:wght@200..700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
  <kt-app>
    <!-- Sidebar (opened by clicking logotype) -->
    <kt-sidebar id="sidebar" hidden>
      <%= KemalTemplate.render_partial("sidebar") %>
    </kt-sidebar>

    <!-- Main content area -->
    <kt-main>
      <!-- Top bar with search -->
      <%= KemalTemplate.render_partial("topbar") %>

      <!-- Page content -->
      <kt-content>
        <%= content %>
      </kt-content>
    </kt-main>
  </kt-app>

  <script src="/js/app.js"></script>
</body>
</html>
