<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Kefine</title>

  <!-- Built CSS from Vite (includes Fontsource fonts, WebAwesome, and TAC CSS Architecture) -->
  <link rel="stylesheet" href="/dist/assets/style.css">
</head>
<body>
  <kf-app>
    <!-- Overlay for sidebar (pre-placed, visibility toggled) -->
    <kf-overlay></kf-overlay>

    <!-- Sidebar (opened by clicking logotype) -->
    <kf-sidebar id="sidebar" hidden>
      <%= KemalTemplate.render_partial("sidebar") %>
    </kf-sidebar>

    <!-- Main content area -->
    <kf-main>
      <!-- Top bar with search -->
      <%= KemalTemplate.render_partial("topbar") %>

      <!-- Page content -->
      <kf-content>
        <%= content %>
      </kf-content>
    </kf-main>
  </kf-app>

  <!-- Built JS from Vite (includes Lit, WebAwesome components, and application code) -->
  <script type="module" src="/dist/assets/main.js"></script>
</body>
</html>
