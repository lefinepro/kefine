<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Kemal Template</title>

  <!-- Built CSS from Vite (includes Fontsource fonts and TAC CSS Architecture) -->
  <link rel="stylesheet" href="/dist/assets/style.css">
</head>
<body>
  <kt-app>
    <!-- Sidebar (opened by clicking logotype) -->
    <kt-sidebar id="sidebar" hidden>
      <%= KemalTemplate.render_partial("sidebar") %>
    </kt-sidebar>

    <!-- Main content area -->
    <kt-main>
      <!-- Top bar with search -->
      <%= KemalTemplate.render_partial("topbar") %>

      <!-- Page content -->
      <kt-content>
        <%= content %>
      </kt-content>
    </kt-main>
  </kt-app>

  <!-- Built JS from Vite -->
  <script type="module" src="/dist/assets/main.js"></script>
</body>
</html>
