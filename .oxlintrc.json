{
  "ignorePatterns": [
    ".bun/**",
    "build/**",
    ".svelte-kit/**",
    ".vite-cache/**",
    "node_modules/**",
    "crater/lib/**"
  ],
  "overrides": [
    {
      "files": [
        "**/*.js",
        "**/*.ts"
      ],
      "rules": {
        "max-lines": [
          "warn",
          500
        ],
        "max-lines-per-function": [
          "warn",
          120
        ],
        "max-depth": [
          "warn",
          4
        ],
        "max-params": [
          "warn",
          4
        ]
      }
    },
    {
      "files": [
        "**/*.svelte"
      ],
      "rules": {
        "max-lines": [
          "warn",
          900
        ],
        "max-lines-per-function": [
          "warn",
          200
        ],
        "max-depth": [
          "warn",
          4
        ],
        "max-params": [
          "warn",
          4
        ]
      }
    },
    {
      "files": [
        "src/lib/components/kefine/KefineWorkspace.svelte"
      ],
      "rules": {
        "max-lines": [
          "warn",
          1300
        ]
      }
    },
    {
      "files": [
        "src/lib/components/kefine/kefine-workflow.ts",
        "src/lib/components/kefine/kefine-workflow-parsers.ts"
      ],
      "rules": {
        "max-lines": [
          "warn",
          700
        ]
      }
    }
  ]
}
