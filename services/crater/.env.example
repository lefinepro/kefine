# Crater Service Environment Variables
# Copy this file to .env and fill in your values

# Server configuration
PORT=3001
BASE_URL=http://localhost:3001

# Simple API URL (main Kefine app)
SIMPLE_API_URL=http://localhost:5173/api

# Actor configuration
ACTOR_NAME=crater
DOMAIN=localhost:3001

# Cryptographic key for HTTP signatures
# Generated on first run if not provided
PRIVATE_KEY=

# Crystal environment (development | production)
CRYSTAL_ENV=development
